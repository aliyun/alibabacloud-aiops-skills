<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Cloud Security Product Configuration Health Report - {{ customer_name }}</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  :root{
    --bg:#0a0a0f;
    --bg-soft:#13131c;
    --bg-card:#1a1a26;
    --border:#26263a;
    --border-strong:#3a3a52;
    --text:#e8e8f0;
    --text-dim:#8a8aa3;
    --text-mute:#5a5a73;
    --accent-1:#5b8def;   /* primary blue */
    --accent-2:#34d399;   /* green ok */
    --accent-3:#f59e0b;   /* amber warn */
    --accent-4:#ef4444;   /* red fail */
    --accent-5:#a78bfa;   /* purple */
    --accent-6:#f0abfc;   /* pink */
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","Helvetica Neue",sans-serif;
    line-height:1.6;
    padding:32px 24px 80px;
  }
  .container{max-width:1200px;margin:0 auto}

  /* ---- Cover ---- */
  .hero{
    background:linear-gradient(135deg,var(--bg-soft) 0%,var(--bg-card) 100%);
    border:1px solid var(--border);
    border-radius:16px;
    padding:40px;
    margin-bottom:24px;
  }
  .hero-eyebrow{
    color:var(--text-mute);
    font-size:12px;
    letter-spacing:2px;
    text-transform:uppercase;
    margin-bottom:8px;
  }
  .hero h1{
    font-size:28px;
    font-weight:600;
    margin-bottom:6px;
    letter-spacing:-0.5px;
  }
  .hero-customer{color:var(--text-dim);font-size:14px;margin-bottom:24px}

  .hero-grid{
    display:grid;
    grid-template-columns:300px 1fr;
    gap:32px;
    align-items:center;
  }
  .score-circle{
    position:relative;
    width:240px;
    height:240px;
    margin:0 auto;
  }
  .score-circle svg{transform:rotate(-90deg)}
  .score-circle .ring-bg{stroke:var(--bg-card);stroke-width:14;fill:none}
  .score-circle .ring-fg{stroke-width:14;fill:none;stroke-linecap:round;
    transition:stroke-dashoffset 1.2s ease}
  .score-text{
    position:absolute;inset:0;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
  }
  .score-num{font-size:64px;font-weight:300;letter-spacing:-2px;line-height:1}
  .score-suffix{color:var(--text-mute);font-size:14px;margin-top:4px}
  .score-grade{
    margin-top:12px;
    padding:4px 14px;
    border-radius:20px;
    font-size:13px;
    font-weight:600;
  }

  .radar-wrap{height:260px;position:relative}

  /* ---- Product Overview (4 cards) ---- */
  .product-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:16px;
    margin-bottom:32px;
  }
  .product-card{
    background:var(--bg-card);
    border:1px solid var(--border);
    border-radius:12px;
    padding:20px;
    position:relative;
    overflow:hidden;
  }
  .product-card::before{
    content:"";
    position:absolute;top:0;left:0;right:0;height:3px;
  }
  .product-card[data-grade="A"]::before{background:var(--accent-2)}
  .product-card[data-grade="B"]::before{background:var(--accent-1)}
  .product-card[data-grade="C"]::before{background:var(--accent-3)}
  .product-card[data-grade="D"]::before{background:var(--accent-4)}

  .product-name{font-size:13px;color:var(--text-dim);margin-bottom:8px}
  .product-score{font-size:32px;font-weight:300;letter-spacing:-1px}
  .product-score-suffix{font-size:13px;color:var(--text-mute);margin-left:4px}
  .product-stats{
    display:flex;gap:10px;margin-top:12px;
    font-size:12px;color:var(--text-dim);
  }
  .stat-pill{
    padding:2px 8px;border-radius:10px;
    background:var(--bg-soft);
    border:1px solid var(--border);
  }
  .stat-pill.full{color:var(--accent-2);border-color:rgba(52,211,153,.3)}
  .stat-pill.partial{color:var(--accent-3);border-color:rgba(245,158,11,.3)}
  .stat-pill.fail{color:var(--accent-4);border-color:rgba(239,68,68,.3)}

  /* ---- Section titles ---- */
  .section{margin-bottom:32px}
  .section-title{
    display:flex;align-items:center;gap:12px;
    font-size:18px;font-weight:600;
    margin-bottom:16px;
    padding-bottom:12px;
    border-bottom:1px solid var(--border);
  }
  .section-title .num{
    width:24px;height:24px;border-radius:6px;
    background:var(--accent-1);
    color:#fff;display:flex;align-items:center;justify-content:center;
    font-size:13px;font-weight:600;
  }
  .section-sub{
    color:var(--text-dim);font-size:13px;font-weight:400;margin-left:auto;
  }

  /* ---- Top 10 Remediation List ---- */
  .remediation-list{display:flex;flex-direction:column;gap:10px}
  .remediation-item{
    background:var(--bg-card);
    border:1px solid var(--border);
    border-radius:10px;
    padding:16px 18px;
    display:grid;
    grid-template-columns:32px 1fr 120px 80px;
    gap:16px;
    align-items:center;
  }
  .rem-rank{
    font-size:18px;font-weight:600;color:var(--text-mute);
    text-align:center;
  }
  .rem-main .rem-name{font-size:15px;font-weight:500;margin-bottom:4px}
  .rem-main .rem-meta{font-size:12px;color:var(--text-dim)}
  .rem-product{
    display:inline-block;padding:2px 8px;border-radius:4px;
    background:var(--bg-soft);font-size:11px;color:var(--text-dim);
    margin-right:6px;
  }
  .rem-effort{font-size:12px;color:var(--text-dim);text-align:center}
  .rem-effort-bar{
    height:4px;border-radius:2px;background:var(--bg-soft);margin-top:4px;
    overflow:hidden;
  }
  .rem-effort-bar > div{height:100%;border-radius:2px}
  .effort-low .rem-effort-bar > div{width:33%;background:var(--accent-2)}
  .effort-medium .rem-effort-bar > div{width:66%;background:var(--accent-3)}
  .effort-high .rem-effort-bar > div{width:100%;background:var(--accent-4)}
  .rem-verdict{text-align:center}
  .badge{
    display:inline-block;padding:4px 10px;border-radius:12px;
    font-size:11px;font-weight:600;letter-spacing:0.5px;
  }
  .badge.full{background:rgba(52,211,153,.15);color:var(--accent-2)}
  .badge.partial{background:rgba(245,158,11,.15);color:var(--accent-3)}
  .badge.fail{background:rgba(239,68,68,.15);color:var(--accent-4)}
  .badge.error{background:rgba(90,90,115,.2);color:var(--text-mute)}

  /* ---- Product detail tabs ---- */
  .tab-nav{
    display:flex;gap:4px;
    border-bottom:1px solid var(--border);
    margin-bottom:16px;
  }
  .tab-nav button{
    background:transparent;border:none;color:var(--text-dim);
    padding:10px 18px;
    cursor:pointer;font-size:14px;
    border-bottom:2px solid transparent;
    transition:all 0.2s;
  }
  .tab-nav button.active{color:var(--text);border-bottom-color:var(--accent-1)}
  .tab-nav button:hover{color:var(--text)}
  .tab-panel{display:none}
  .tab-panel.active{display:block}

  .check-table{
    width:100%;border-collapse:collapse;
    background:var(--bg-card);border:1px solid var(--border);border-radius:10px;
    overflow:hidden;
  }
  .check-table th,.check-table td{
    padding:12px 14px;text-align:left;font-size:13px;
    border-bottom:1px solid var(--border);
  }
  .check-table th{
    background:var(--bg-soft);font-weight:500;color:var(--text-dim);
    font-size:12px;letter-spacing:0.5px;text-transform:uppercase;
  }
  .check-table tr:last-child td{border-bottom:none}
  .check-table tr:hover td{background:rgba(91,141,239,.05)}
  .check-name{font-weight:500}
  .check-category{
    display:inline-block;padding:1px 6px;border-radius:3px;
    background:var(--bg-soft);font-size:11px;color:var(--text-mute);
    margin-left:6px;
  }
  .check-value{color:var(--text-dim);font-family:"SF Mono",Menlo,monospace;font-size:12px}

  /* ---- Footer ---- */
  .footer{
    margin-top:48px;
    text-align:center;
    color:var(--text-mute);
    font-size:12px;
  }
  .footer a{color:var(--accent-1);text-decoration:none}
</style>
</head>
<body>
<div class="container">

  <!-- Cover -->
  <div class="hero">
    <div class="hero-eyebrow">CLOUD SECURITY HEALTH CHECK</div>
    <h1>Cloud Security Product Configuration Health Report</h1>
    <div class="hero-customer">Customer: {{ customer_name }} - Generated: {{ generated_at }}</div>

    <div class="hero-grid">
      <!-- Overall score ring -->
      <div>
        <div class="score-circle">
          <svg width="240" height="240" viewBox="0 0 240 240">
            <circle class="ring-bg" cx="120" cy="120" r="100"/>
            <circle class="ring-fg" cx="120" cy="120" r="100"
              stroke="{{ grade_color }}"
              stroke-dasharray="{{ 6.283 * 100 }}"
              stroke-dashoffset="{{ 6.283 * 100 * (1 - overall_score / 100) }}"/>
          </svg>
          <div class="score-text">
            <div class="score-num" style="color:{{ grade_color }}">{{ overall_score }}</div>
            <div class="score-suffix">/ 100</div>
            <div class="score-grade" style="background:{{ grade_color }}20;color:{{ grade_color }}">
              Grade {{ overall_grade }} - {{ grade_label }}
            </div>
          </div>
        </div>
      </div>

      <!-- Radar chart -->
      <div>
        <div class="radar-wrap">
          <canvas id="radar"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Product cards -->
  <div class="product-grid">
    {% for p in products %}
    <div class="product-card" data-grade="{{ p.grade }}">
      <div class="product-name">{{ p.name }}</div>
      <div>
        <span class="product-score">{{ p.score }}</span>
        <span class="product-score-suffix">/ 100</span>
      </div>
      <div class="product-stats">
        <span class="stat-pill full">{{ p.full }}✓</span>
        <span class="stat-pill partial">{{ p.partial }}△</span>
        <span class="stat-pill fail">{{ p.fail }}✗</span>
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- Top 10 Remediation -->
  <div class="section">
    <div class="section-title">
      <span class="num">1</span>
      <span>Priority Remediation Items Top 10</span>
      <span class="section-sub">Sorted by Severity x Effort composite ranking</span>
    </div>
    <div class="remediation-list">
      {% for item in top10 %}
      <div class="remediation-item">
        <div class="rem-rank">#{{ loop.index }}</div>
        <div class="rem-main">
          <div class="rem-name">{{ item.name }}</div>
          <div class="rem-meta">
            <span class="rem-product">{{ item.product_label }}</span>
            <span>{{ item.category }} - Weight {{ item.weight }} - Current: <code>{{ item.actual_value }}</code></span>
          </div>
        </div>
        <div class="rem-effort effort-{{ item.effort }}">
          Effort: {{ item.effort_label }}
          <div class="rem-effort-bar"><div></div></div>
        </div>
        <div class="rem-verdict">
          <span class="badge {{ item.verdict }}">{{ item.verdict_label }}</span>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- Product Details -->
  <div class="section">
    <div class="section-title">
      <span class="num">2</span>
      <span>Detailed Check Items by Product</span>
      <span class="section-sub">{{ total_checks }} total checks</span>
    </div>
    <div class="tab-nav">
      {% for p in products %}
      <button class="{% if loop.first %}active{% endif %}" data-tab="{{ p.id }}">
        {{ p.name }} ({{ p.score }})
      </button>
      {% endfor %}
    </div>

    {% for p in products %}
    <div class="tab-panel {% if loop.first %}active{% endif %}" data-panel="{{ p.id }}">
      <table class="check-table">
        <thead>
          <tr>
            <th style="width:30%">Check Item</th>
            <th style="width:10%">Weight</th>
            <th style="width:25%">Current Value</th>
            <th style="width:10%">Effort</th>
            <th style="width:15%">Status</th>
            <th style="width:10%">Reference</th>
          </tr>
        </thead>
        <tbody>
        {% for chk in p.checks %}
          <tr>
            <td>
              <div class="check-name">{{ chk.name }}</div>
              <span class="check-category">{{ chk.category }}</span>
            </td>
            <td>{{ chk.weight }}</td>
            <td class="check-value">{{ chk.actual_value }}</td>
            <td>{{ chk.effort_label }}</td>
            <td><span class="badge {{ chk.verdict }}">{{ chk.verdict_label }}</span></td>
            <td><a href="{{ chk.doc }}" target="_blank" style="color:var(--accent-1);text-decoration:none">Docs↗</a></td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
    {% endfor %}
  </div>

  <div class="footer">
    Generated by <strong>alibabacloud-security-health-check</strong> - Report contains only customer-submitted configuration data, no credentials transferred
    <br>
    Scoring model: Each item scored as full / partial / fail with weighted calculation -> normalized to 100 per product -> overall average across purchased products
  </div>

</div>

<script>
  // Radar chart
  const radarData = {{ radar_data | tojson }};
  new Chart(document.getElementById('radar'), {
    type:'radar',
    data:{
      labels: radarData.labels,
      datasets:[{
        label:'Current Configuration Score',
        data: radarData.scores,
        backgroundColor:'rgba(91,141,239,0.15)',
        borderColor:'rgba(91,141,239,0.9)',
        borderWidth:2,
        pointBackgroundColor:'rgba(91,141,239,1)',
        pointRadius:4,
      },{
        label:'Industry Baseline (75)',
        data: radarData.labels.map(()=>75),
        backgroundColor:'rgba(167,139,250,0.05)',
        borderColor:'rgba(167,139,250,0.4)',
        borderWidth:1,
        borderDash:[4,4],
        pointRadius:0,
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      scales:{
        r:{
          min:0,max:100,
          angleLines:{color:'rgba(58,58,82,0.5)'},
          grid:{color:'rgba(58,58,82,0.5)'},
          pointLabels:{color:'#e8e8f0',font:{size:13}},
          ticks:{color:'#5a5a73',backdropColor:'transparent',stepSize:25},
        }
      },
      plugins:{
        legend:{labels:{color:'#8a8aa3'}}
      }
    }
  });

  // Tab switching
  document.querySelectorAll('.tab-nav button').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const id = btn.dataset.tab;
      document.querySelectorAll('.tab-nav button').forEach(b=>b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
      btn.classList.add('active');
      document.querySelector(`[data-panel="${id}"]`).classList.add('active');
    });
  });
</script>
</body>
</html>
