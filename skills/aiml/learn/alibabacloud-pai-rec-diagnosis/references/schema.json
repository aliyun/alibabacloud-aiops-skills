    },
    "RecallEngineConfig": {
      "type": "object",
      "required": ["Username", "Password"],
      "properties": {
        "Username": {
          "type": "string",
          "description": "Recall-engine username"
        },
        "Password": {
          "type": "string",
          "description": "Recall-engine password"
        },
        "Endpoint": {
          "type": "string",
          "description": "Recall-engine service endpoint (optional; auto-detected in PAI-EAS)"
        },
        "Authorization": {
          "type": "string",
          "description": "Custom auth header (optional)"
        },
        "InstanceId": {
          "type": "string",
          "description": "Instance ID (optional; read from env vars in PAI-EAS)"
        }
      },
      "additionalProperties": false
    },
    "RecallEngineConf": {
      "type": "object",
      "required": ["RecallEngineName", "ServiceName", "RecallEngineParams"],
      "properties": {
        "RecallEngineName": {
          "type": "string",
          "description": "Recall data source name, defined in RecallEngineConfs"
        },
        "ServiceName": {
          "type": "string",
          "description": "Recall service name"
        },
        "VersionName": {
          "type": "string",
          "description": "Recall service version (optional; defaults to the active online version)"
        },
        "RecallEngineParams": {
          "type": "array",
          "items": { "$ref": "#/definitions/RecallEngineParam" },
          "description": "Specific configuration for this recall"
        },
        "FilterNames": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Filter name list (optional)"
        }
      },
      "additionalProperties": false
    },
    "RecallEngineParam": {
      "type": "object",
      "required": ["RecallType", "RecallName", "Count"],
      "properties": {
        "RecallType": {
          "type": "string",
          "enum": ["x2i", "vector", "random"],
          "description": "Recall type: x2i, vector, or random"
        },
        "RecallName": {
          "type": "string",
          "description": "Recall name configured in the recall-management service"
        },
        "Count": {
          "type": "integer",
          "minimum": 1,
          "description": "Recall count; if filters are configured, this is the post-filter count"
        },
        "TriggerType": {
          "type": "string",
          "enum": ["user", "item", "fixvalue", "u2i_realtime"],
          "description": "Trigger type: user, item, fixvalue, or u2i_realtime"
        },
        "TriggerValue": {
          "type": "string",
          "description": "Trigger fixed value (for fixvalue type, e.g. -1 for global hot)"
        },
        "UserTriggers": {
          "type": "array",
          "items": { "$ref": "#/definitions/UserTrigger" },
          "description": "User trigger configuration (for user type)"
        },
        "UserTriggerDaoConf": {
          "$ref": "#/definitions/UserTriggerDaoConf",
          "description": "User trigger data configuration (for u2i_realtime type)"
        }
      },
      "additionalProperties": false
    },
    "UserTrigger": {
      "type": "object",
      "required": ["TriggerKey"],
      "properties": {
        "TriggerKey": {
          "type": "string",
          "description": "Trigger key, e.g. uid, gender, age"
        },
        "Boundaries": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Numeric bucketing boundaries (optional; used for numeric fields such as age)"
        }
      },
      "additionalProperties": false
    },
    "UserTriggerDaoConf": {
      "type": "object",
      "required": ["AdapterType"],
      "properties": {
        "AdapterType": {
          "type": "string",
          "enum": ["hologres", "featurestore"],
          "description": "Data source type"
        },
        "HologresName": {
          "type": "string",
          "description": "Data source name defined in HologresConfs (required for Hologres)"
        },
        "HologresTableName": {
          "type": "string",
          "description": "User-behavior table name (required for Hologres)"
        },
        "FeatureStoreName": {
          "type": "string",
          "description": "Data source name defined in FeatureStoreConfs (required for FeatureStore)"
        },
        "FeatureStoreViewName": {
          "type": "string",
          "description": "FeatureView name for user behavior (required for FeatureStore)"
        },
        "WhereClause": {
          "type": "string",
          "description": "SQL filter clause (optional)"
        },
        "Limit": {
          "type": "integer",
          "description": "Query result limit (optional)"
        },
        "TriggerCount": {
          "type": "integer",
          "description": "Trigger count (optional)"
        },
        "EventPlayTime": {
          "type": "string",
          "description": "Event play-time filter; format event1:time1;event2:time2 (optional)"
        },
        "EventWeight": {
          "type": "string",
          "description": "Event weight configuration; format event1:weight1;event2:weight2 (optional)"
        },
        "WeightExpression": {
          "type": "string",
          "description": "Weight expression; supports currentTime and eventTime variables (optional)"
        },
        "WeightMode": {
          "type": "string",
          "enum": ["sum", "max"],
          "description": "Weight aggregation mode: sum or max; defaults to sum (optional)"
        },
        "NoUsePlayTimeField": {
          "type": "boolean",
          "description": "Whether to ignore the play-duration field (optional)"
        },
        "ItemIdFieldName": {
          "type": "string",
          "description": "Item ID field name; defaults to item_id (optional)"
        },
        "EventFieldName": {
          "type": "string",
          "description": "Event field name; defaults to event (optional)"
        },
        "PlayTimeFieldName": {
          "type": "string",
          "description": "Play-duration field name; defaults to playtime (optional)"
        },
        "TimestampFieldName": {
          "type": "string",
          "description": "Timestamp field name; defaults to event_time (optional)"
        }
      },
      "additionalProperties": false
    }
  }
